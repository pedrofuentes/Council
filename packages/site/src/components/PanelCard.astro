---
/**
 * A single panel card for the gallery. Every field is sourced from the panel
 * YAML via {@link PanelSummary}; there are no quality, popularity, or maturity
 * claims. The usage snippet always uses the correct convene syntax — a quoted
 * topic plus `--panel <slug>` — so it is copy-paste ready.
 */
import type { PanelSummary } from "../lib/panels/panel-model";

interface Props {
  readonly panel: PanelSummary;
}

const { panel } = Astro.props;
const titleId = `panel-${panel.slug}-title`;
const [leadPrompt, ...morePrompts] = panel.samplePrompts;
---

<article class="panel-card" aria-labelledby={titleId}>
  <header class="panel-card__header">
    <div class="panel-card__heading">
      <h3 id={titleId} class="panel-card__title">{panel.name}</h3>
      <code class="panel-card__slug">{panel.slug}</code>
    </div>
    <span class="panel-card__discipline">{panel.discipline}</span>
  </header>

  {
    panel.regulatedDomain && (
      <p class="panel-card__regulated">
        <span class="badge badge--regulated">{panel.regulatedDomain.label}</span>
        <span class="panel-card__regulated-note">
          Decision-support — not professional {panel.regulatedDomain.domain} advice.
        </span>
      </p>
    )
  }

  <p class="panel-card__description">{panel.description}</p>

  <div class="panel-card__section">
    <h4 class="panel-card__subhead">{panel.expertCount} experts</h4>
    <ul class="panel-card__experts">
      {
        panel.experts.map((expert) => (
          <li class="panel-card__expert">
            <span class="panel-card__expert-name">{expert.displayName}</span>
            <span class="panel-card__expert-role">{expert.role}</span>
          </li>
        ))
      }
    </ul>
  </div>

  {
    panel.decisionArtifact && (
      <div class="panel-card__section">
        <h4 class="panel-card__subhead">Decision artifact</h4>
        <p class="panel-card__artifact">{panel.decisionArtifact}</p>
      </div>
    )
  }

  {
    leadPrompt && (
      <div class="panel-card__section">
        <h4 class="panel-card__subhead">Example prompt</h4>
        <p class="panel-card__prompt">{leadPrompt}</p>
        {morePrompts.length > 0 && (
          <details class="panel-card__more">
            <summary>{morePrompts.length} more example{morePrompts.length > 1 ? "s" : ""}</summary>
            <ul>
              {morePrompts.map((prompt) => (
                <li>{prompt}</li>
              ))}
            </ul>
          </details>
        )}
      </div>
    )
  }

  {
    panel.tags.length > 0 && (
      <ul class="panel-card__tags" aria-label="Tags">
        {panel.tags.map((tag) => (
          <li class="tag">{tag}</li>
        ))}
      </ul>
    )
  }

  <figure class="panel-card__usage">
    <figcaption class="panel-card__subhead">Run this panel</figcaption>
    <div class="panel-card__snippet">
      <pre><code>{panel.conveneCommand}</code></pre>
      <button
        type="button"
        class="copy-button"
        data-copy={panel.conveneCommand}
        aria-label={`Copy the convene command for ${panel.name}`}
      >
        Copy
      </button>
    </div>
  </figure>
</article>

<style>
  .panel-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--council-color-text-muted) 24%, transparent);
    border-radius: 0.75rem;
    background: var(--council-color-surface);
    color: var(--council-color-text);
  }

  .panel-card__header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem 1rem;
  }

  .panel-card__heading {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .panel-card__title {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.25;
  }

  .panel-card__slug {
    font-family: var(--council-font-mono);
    font-size: 0.75rem;
    color: var(--council-color-text-muted);
  }

  .panel-card__discipline {
    align-self: flex-start;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--council-color-bg);
    background: var(--council-color-primary);
  }

  .panel-card__regulated {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
  }

  .badge {
    padding: 0.2rem 0.55rem;
    border-radius: 0.4rem;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .badge--regulated {
    color: var(--council-color-bg);
    background: var(--council-color-accent-amber);
  }

  .panel-card__regulated-note {
    font-size: 0.75rem;
    color: var(--council-color-text-muted);
  }

  .panel-card__description {
    margin: 0;
    line-height: 1.55;
  }

  .panel-card__section {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .panel-card__subhead {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--council-color-text-muted);
  }

  .panel-card__experts {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .panel-card__expert {
    display: flex;
    flex-direction: column;
    line-height: 1.35;
  }

  .panel-card__expert-name {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .panel-card__expert-role {
    font-size: 0.8rem;
    color: var(--council-color-text-muted);
  }

  .panel-card__artifact,
  .panel-card__prompt {
    margin: 0;
    line-height: 1.5;
  }

  .panel-card__prompt {
    padding-left: 0.75rem;
    border-left: 2px solid var(--council-color-primary);
    font-style: italic;
  }

  .panel-card__more {
    font-size: 0.85rem;
  }

  .panel-card__more summary {
    cursor: pointer;
    color: var(--council-color-primary-hover);
  }

  .panel-card__more ul {
    margin: 0.5rem 0 0;
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .panel-card__tags {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    color: var(--council-color-text-muted);
    background: color-mix(in srgb, var(--council-color-text-muted) 14%, transparent);
  }

  .panel-card__usage {
    margin: auto 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .panel-card__snippet {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
  }

  .panel-card__snippet pre {
    flex: 1;
    margin: 0;
    padding: 0.6rem 0.75rem;
    overflow-x: auto;
    border-radius: 0.5rem;
    background: var(--council-color-bg);
    border: 1px solid color-mix(in srgb, var(--council-color-text-muted) 20%, transparent);
  }

  .panel-card__snippet code {
    font-family: var(--council-font-mono);
    font-size: 0.78rem;
    white-space: pre;
  }

  .copy-button {
    flex-shrink: 0;
    padding: 0 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid var(--council-color-primary);
    background: transparent;
    color: var(--council-color-text);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
  }

  .copy-button:hover,
  .copy-button:focus-visible {
    background: color-mix(in srgb, var(--council-color-primary) 18%, transparent);
  }

  @media (max-width: 28rem) {
    .panel-card__snippet {
      flex-direction: column;
    }

    .copy-button {
      padding: 0.4rem 0.75rem;
    }
  }
</style>
