---
/**
 * BrandMark - Council Logo Component
 *
 * Renders the Council circuit-board emblem + COUNCIL wordmark.
 * Council-first branding per project brand guidelines.
 *
 * @remarks
 * The wordmark's `<style>` block reads `--council-font-mono` and
 * `--council-color-text` custom properties, both defined in
 * `../styles/tokens.css`. Consuming pages/layouts MUST import that
 * stylesheet (e.g. `import "../styles/tokens.css";`, as done in
 * `gallery.astro` and `content/docs/index.mdx`) or this component
 * silently falls back to the hard-coded `monospace` font and
 * `#1b2c32`/`#e6e9e6` text colors instead of the brand tokens.
 */

interface Props {
  /**
   * Logo size in pixels (height and width)
   * @default 80
   */
  size?: number;
  /**
   * Whether to include the wordmark text below the emblem
   * @default true
   */
  showWordmark?: boolean;
  /**
   * Additional CSS class names
   */
  class?: string;
}

const { size = 80, showWordmark = true, class: className } = Astro.props;
---

<div class:list={['council-brandmark', className]}>
  <img
    src={`${import.meta.env.BASE_URL}brand/council-logo.png`}
    alt="Council"
    width={size}
    height={size}
    class="council-logo-emblem"
  />
  {
    showWordmark && (
      <span class="council-wordmark">
        COUNCIL
      </span>
    )
  }
</div>

<style>
  .council-brandmark {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .council-logo-emblem {
    display: block;
  }

  .council-wordmark {
    font-family: var(--council-font-mono, monospace);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--council-color-text, #1b2c32);
  }

  @media (prefers-color-scheme: dark) {
    .council-wordmark {
      color: var(--council-color-text, #e6e9e6);
    }
  }
</style>
