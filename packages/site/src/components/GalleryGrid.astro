---
/**
 * Responsive grid of {@link PanelCard}s for one set of panels (typically a
 * single discipline section). Falls back to the honest empty state only when
 * there are genuinely no panels to show.
 */
import type { PanelSummary } from "../lib/panels/panel-model";
import EmptyState from "./EmptyState.astro";
import PanelCard from "./PanelCard.astro";

interface Props {
  readonly panels: readonly PanelSummary[];
}

const { panels } = Astro.props;
---

{
  panels.length === 0 ? (
    <EmptyState />
  ) : (
    <div class="gallery-grid">
      {panels.map((panel) => (
        <PanelCard panel={panel} />
      ))}
    </div>
  )
}

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 1.5rem;
  }
</style>
