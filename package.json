{
  "name": "@council/cli",
  "version": "0.1.0",
  "description": "Persistent AI expert panels that deliberate, disagree, and remember.",
  "type": "module",
  "license": "MIT",
  "author": "Pedro Fuentes",
  "homepage": "https://github.com/pedrofuentes/Council",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrofuentes/Council.git"
  },
  "bugs": {
    "url": "https://github.com/pedrofuentes/Council/issues"
  },
  "keywords": [
    "ai",
    "cli",
    "multi-agent",
    "deliberation",
    "decision-making",
    "github-copilot"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "council": "./dist/bin/council.js"
  },
  "files": [
    "dist",
    "panels",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@github/copilot-sdk": "~0.3.0",
    "@libsql/client": "^0.8.0",
    "@libsql/kysely-libsql": "^0.4.1",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "ink": "^7.0.2",
    "ink-spinner": "^5.0.0",
    "kysely": "^0.28.17",
    "react": "^19.2.6",
    "ulid": "^3.0.2",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
