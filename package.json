{
  "name": "council",
  "version": "0.1.0",
  "description": "Council monorepo — persistent AI expert panels that deliberate, disagree, and remember.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Pedro Fuentes",
  "homepage": "https://github.com/pedrofuentes/Council",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrofuentes/Council.git"
  },
  "bugs": {
    "url": "https://github.com/pedrofuentes/Council/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter @council-ai/cli build",
    "dev": "pnpm --filter @council-ai/cli dev",
    "test": "pnpm --filter @council-ai/cli test",
    "test:unit": "pnpm --filter @council-ai/cli test:unit",
    "test:e2e": "pnpm --filter @council-ai/cli test:e2e",
    "test:integration": "pnpm --filter @council-ai/cli test:integration",
    "test:security": "pnpm --filter @council-ai/cli test:security",
    "test:watch": "pnpm --filter @council-ai/cli test:watch",
    "test:coverage": "pnpm --filter @council-ai/cli test:coverage",
    "lint": "eslint packages/cli/src packages/cli/tests",
    "lint:fix": "eslint packages/cli/src packages/cli/tests --fix",
    "typecheck": "pnpm --filter @council-ai/cli typecheck",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/yauzl": "2.10.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.17.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5": "5.0.6",
      "ws@>=8": "8.21.0",
      "uuid@<11.1.1": ">=11.1.1",
      "js-yaml@<4.2.0": ">=4.2.0",
      "esbuild@<0.28.1": ">=0.28.1"
    }
  }
}
